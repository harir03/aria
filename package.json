{
  "name": "aria-monorepo",
  "private": true,
  "description": "ARIA — Adaptive Response & Intelligence Agent — Monorepo Root",
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "start:gateway": "npm run start -w apps/gateway",
    "install:all": "npm install",
    "docker:up": "cd infrastructure && docker-compose up -d",
    "docker:down": "cd infrastructure && docker-compose down",
    "db:seed": "node infrastructure/seed_node.js"
  }
}
